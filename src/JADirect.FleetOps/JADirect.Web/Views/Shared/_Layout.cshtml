<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - JADirect</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    
    <script src="https://cdn.tailwindcss.com"></script>
    
    <style>
        /* Efeito de Vidro Teal para a Navbar */
        .glass-nav {
            background: rgba(0, 128, 128, 0.95);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
        }
        
        /* Ajuste do Dropdown para parecer um Card moderno */
        .dropdown-menu { 
            border-radius: 12px; 
            border: none; 
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            padding: 0.5rem;
            min-width: 200px;
        }

        .dropdown-item {
            border-radius: 8px;
            padding: 0.6rem 1rem;
            transition: all 0.2s;
        }

        .dropdown-item:hover {
            background-color: #f0fdfa;
            color: #0d9488;
        }

        /* Remove a seta padrão do dropdown do bootstrap para o nosso design limpo */
        .dropdown-toggle::after {
            display: none;
        }
    </style>
</head>
<body class="bg-slate-50">
<header>
    <nav class="glass-nav sticky top-0 z-50 text-white shadow-lg mb-8">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                
                <div class="flex items-center">
                    <a asp-controller="Home" asp-action="Index" class="flex items-center no-underline">
                        <img src="~/images/logo-white.png" alt="JA Direct Logo" class="h-10 w-auto object-contain" />
                    </a>
                </div>

                <div class="flex items-center">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <div class="dropdown">
                            <button class="flex items-center space-x-3 focus:outline-none dropdown-toggle border-0 bg-transparent text-white" 
                                    type="button" 
                                    id="userMenu" 
                                    data-bs-toggle="dropdown" 
                                    aria-expanded="false">
                                
                                <div class="text-right hidden sm:block">
                                    <p class="text-[10px] text-teal-200 uppercase tracking-widest leading-none mb-1 font-bold">Driver Online</p>
                                    <p class="text-sm font-bold">@User.Identity.Name</p>
                                </div>
                                
                                <div class="h-10 w-10 bg-white/20 hover:bg-white/30 rounded-full flex items-center justify-center border border-white/40 transition-all shadow-inner">
                                    <i class="ri-user-settings-line text-lg"></i>
                                </div>
                            </button>

                            <ul class="dropdown-menu dropdown-menu-end mt-2 animate-in fade-in slide-in-from-top-2" aria-labelledby="userMenu">
                                <li>
                                    <div class="px-4 py-2 border-bottom mb-2 bg-slate-50 rounded-t-lg">
                                        <p class="text-[10px] text-gray-400 uppercase font-bold tracking-tighter mb-0">Logged as</p>
                                        <p class="text-sm font-bold text-teal-800">@User.Identity.Name</p>
                                    </div>
                                </li>
                                <li>
                                    <a class="dropdown-item flex items-center text-slate-700" href="#">
                                        <i class="ri-lock-password-line mr-2 text-teal-600"></i> Change Password
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item flex items-center text-slate-700" href="#">
                                        <i class="ri-phone-line mr-2 text-teal-600"></i> Update Phone
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider mx-2"></li>
                                <li>
                                    <a class="dropdown-item flex items-center text-red-600 font-bold" asp-controller="Account" asp-action="Logout">
                                        <i class="ri-logout-box-r-line mr-2"></i> Sign Out
                                    </a>
                                </li>
                            </ul>
                        </div>
                    }
                </div>
            </div>
        </div>
    </nav>
</header>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <main role="main" class="pb-12">
        @RenderBody()
    </main>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html> 