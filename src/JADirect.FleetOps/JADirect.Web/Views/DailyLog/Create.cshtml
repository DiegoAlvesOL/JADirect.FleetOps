@model JADirect.Domain.Entities.DailyLog

@{
ViewData["Title"] = "Daily Operational Log";
}

<style>
    .bg-teal { background-color: #008080; }
    .text-teal { color: #008080; }
    .btn-save-teal {
        background-color: #008080;
        color: white;
        border: none;
        border-radius: 12px;
        font-weight: 700;
        transition: 0.3s;
    }
    .btn-save-teal:hover {
        background-color: #006666;
        transform: scale(1.02);
        color: white;
        box-shadow: 0 10px 20px -5px rgba(0, 128, 128, 0.4);
    }
    .btn-cancel-light {
        background-color: #f8fafc;
        color: #64748b;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        font-weight: 600;
    }
    ::placeholder {
        color: #cbd5e1 !important;
        opacity: 1;
    }
</style>

<div class="max-w-2xl mx-auto p-4">

    @* Link de voltar discreto no topo *@
    <div class="mb-4">
        <a asp-controller="Home" asp-action="Index" class="text-teal text-decoration-none flex items-center font-medium">
            <i class="ri-arrow-left-line mr-1"></i> Back to Dashboard
        </a>
    </div>

    <div class="w-full mx-auto mb-12">
        <div class="bg-white rounded-2xl shadow-2xl overflow-hidden border border-gray-100">

            <div class="bg-teal text-white p-6 flex justify-center items-center">
                <h4 class="text-2xl font-bold mb-0 flex items-center">
                    @* Ícone bi-truck conforme solicitado *@
                    <i class="bi bi-truck text-3xl mr-3"></i> Daily Log Submission
                </h4>
            </div>

            <div class="p-8">
                <form asp-action="Create" method="post" id="dailyLogForm">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-red-700 bg-red-50 border border-red-200 p-3 rounded-lg mb-6 text-sm"></div>

                    <div class="space-y-6">
                        <div>
                            <label asp-for="Deliveries" class="block text-lg font-medium text-gray-700 mb-2">
                                <i class="ri-edit-box-line text-teal mr-1"></i> Deliveries Completed
                            </label>
                            <input asp-for="Deliveries"
                                   class="w-full p-4 text-xl border border-gray-300 rounded-xl focus:ring-4 focus:ring-teal-100 focus:border-teal-600 transition-all font-semibold limit-999"
                                   type="text" inputmode="numeric" placeholder="0" value="" required />
                        </div>

                        <div>
                            <label asp-for="Collections" class="block text-lg font-medium text-gray-700 mb-2">
                                <i class="ri-arrow-left-right-line text-teal mr-1"></i> Collections Made
                            </label>
                            <input asp-for="Collections"
                                   class="w-full p-4 text-xl border border-gray-300 rounded-xl focus:ring-4 focus:ring-teal-100 focus:border-teal-600 transition-all font-semibold limit-999"
                                   type="text" inputmode="numeric" placeholder="0" value="" required />
                        </div>

                        <div>
                            <label asp-for="Returns" class="block text-lg font-medium text-gray-700 mb-2">
                                <i class="ri-arrow-go-back-line text-teal mr-1"></i> Returns Count
                            </label>
                            <input asp-for="Returns"
                                   class="w-full p-4 text-xl border border-gray-300 rounded-xl focus:ring-4 focus:ring-teal-100 focus:border-teal-600 transition-all font-semibold limit-999"
                                   type="text" inputmode="numeric" placeholder="0" value="" required />
                        </div>

                        <div>
                            <label asp-for="CurrentOdometer" class="block text-lg font-medium text-gray-700 mb-2">
                                <i class="ri-dashboard-3-line text-teal mr-1"></i> Final Odometer (Optional)
                            </label>
                            <input asp-for="CurrentOdometer"
                                   class="w-full p-4 text-xl border border-gray-200 bg-gray-50 rounded-xl focus:ring-4 focus:ring-gray-100 focus:border-gray-400 transition-all text-gray-600 font-medium"
                                   type="text" inputmode="numeric" placeholder="KM reading" value="" />
                        </div>

                        <div>
                            <label asp-for="Notes" class="block text-lg font-medium text-gray-700 mb-2">
                                <i class="ri-chat-1-line text-teal mr-1"></i> Notes / Observations
                            </label>
                            <textarea asp-for="Notes" rows="2" class="w-full p-4 text-lg border border-gray-300 rounded-xl focus:ring-4 focus:ring-teal-100 focus:border-teal-600 transition-all"
                                      placeholder="Any issues or remarks..."></textarea>
                        </div>
                    </div>

                    <div class="mt-10 space-y-4">
                        <button type="submit" class="w-full btn-save-teal py-4 text-xl flex justify-center items-center shadow-lg">
                            <i class="ri-check-double-line mr-2"></i> Save Record
                        </button>

                        <a asp-controller="Home" asp-action="Index" class="w-full btn-cancel-light py-3 flex justify-center items-center no-underline">
                            <i class="ri-close-circle-line mr-2"></i> Cancel Entry
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.querySelectorAll('.limit-999').forEach(input => {
        input.addEventListener('input', function() {
            this.value = this.value.replace(/[^0-9]/g, '');
            if (this.value !== '' && parseInt(this.value) > 999) {
                this.value = '999';
            }
        });
    });
</script>
}