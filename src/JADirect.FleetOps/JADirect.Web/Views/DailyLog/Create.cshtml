@model JADirect.Domain.Entities.DailyLog

@{
    ViewData["Title"] = "Daily Operational Log";
    var brandTeal = "#008080";
    var brandTealDark = "#006666";
}

@* ESTILOS CUSTOMIZADOS:
    Define a identidade visual Teal e o comportamento dos botões.
*@
<style>
    .bg-teal { background-color: #008080; }
    .text-teal { color: #008080; }
    .border-teal { border-color: #008080; }
    
    .btn-save-teal {
        background-color: #008080;
        color: white;
        border: none;
        border-radius: 12px;
        font-weight: 700;
        transition: 0.3s;
    }
    .btn-save-teal:hover {
        background-color: #006666;
        transform: scale(1.02);
        color: white;
        box-shadow: 0 10px 20px -5px rgba(0, 128, 128, 0.4);
    }

    .btn-cancel-light {
        background-color: #f8fafc;
        color: #64748b;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        font-weight: 600;
        transition: 0.2s;
    }
    .btn-cancel-light:hover {
        background-color: #f1f5f9;
        color: #334155;
        border-color: #cbd5e1;
    }
</style>

<div class="max-w-4xl mx-auto p-4">
    
    <div class="w-full lg:w-4/5 mx-auto mb-12 mt-6">
        <div class="bg-white rounded-2xl shadow-2xl overflow-hidden border border-gray-100">
            
            <div class="bg-teal text-white p-6 flex justify-center items-center">
                <h4 class="text-2xl font-bold mb-0 flex items-center">
                    <i class="ri-truck-line text-3xl mr-3"></i> Daily Log Submission
                </h4>
            </div>
            
            <div class="p-8">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                        
                    <div asp-validation-summary="ModelOnly" class="text-red-700 bg-red-50 border border-red-200 p-3 rounded-lg mb-6 text-sm"></div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div class="mb-2">
                            <label asp-for="Deliveries" class="block text-lg font-light text-gray-700 mb-2">Deliveries Completed</label>
                            <input asp-for="Deliveries" class="w-full p-4 text-xl border border-gray-300 rounded-xl focus:outline-none focus:ring-4 focus:ring-teal-100 focus:border-teal-600 transition-all font-semibold" 
                                   type="number" min="0" placeholder="0" required />
                        </div>

                        <div class="mb-2">
                            <label asp-for="Collections" class="block text-lg font-light text-gray-700 mb-2">Collections Made</label>
                            <input asp-for="Collections" class="w-full p-4 text-xl border border-gray-300 rounded-xl focus:outline-none focus:ring-4 focus:ring-teal-100 focus:border-teal-600 transition-all font-semibold" 
                                   type="number" min="0" placeholder="0" required />
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-6">
                        <div class="mb-2">
                            <label asp-for="Returns" class="block text-lg font-light text-gray-700 mb-2">Returns Count</label>
                            <input asp-for="Returns" class="w-full p-4 text-xl border border-gray-300 rounded-xl focus:outline-none focus:ring-4 focus:ring-teal-100 focus:border-teal-600 transition-all font-semibold" 
                                   type="number" min="0" placeholder="0" required />
                        </div>

                        <div class="mb-2">
                            <label asp-for="CurrentOdometer" class="block text-lg font-light text-gray-700 mb-2">Final Odometer (Optional)</label>
                            <input asp-for="CurrentOdometer" class="w-full p-4 text-xl border border-gray-200 bg-gray-50 rounded-xl focus:outline-none focus:ring-4 focus:ring-gray-100 focus:border-gray-400 transition-all text-gray-600 font-medium" 
                                   type="number" placeholder="KM reading" />
                        </div>
                    </div>

                    <div class="mt-6">
                        <label asp-for="Observation" class="block text-lg font-light text-gray-700 mb-2">Notes / Observations</label>
                        <textarea asp-for="Observation" rows="3" class="w-full p-4 text-lg border border-gray-300 rounded-xl focus:outline-none focus:ring-4 focus:ring-teal-100 focus:border-teal-600 transition-all" 
                                  placeholder="Any issues, flat tires, or customer remarks..."></textarea>
                    </div>

                    <div class="mt-10 space-y-4">
                        <button type="submit" class="w-full btn-save-teal py-4 text-xl flex justify-center items-center shadow-lg">
                            <i class="ri-save-line mr-2"></i> Save Record
                        </button>
                        
                        <a asp-controller="Home" asp-action="Index" class="w-full btn-cancel-light py-3 flex justify-center items-center no-underline">
                            <i class="ri-close-circle-line mr-2"></i> Cancel Entry
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="mt-12 opacity-40">
        <h4 class="text-xl font-bold mb-6 text-teal flex items-center">
            <i class="ri-history-line mr-2"></i> Recent Logs
        </h4>
        <div class="bg-white rounded-xl p-8 text-center border-2 border-dashed border-gray-200">
            <p class="text-gray-500 font-medium italic">History will be synchronized after your first valid submission.</p>
        </div>
    </div>
</div>