@model JADirect.Domain.Models.UserManagementViewModel
@* Interface de gestão JA Direct. 
   Consome o ViewModel de Domínio e respeita os campos first_name/surname. *@

@{
    ViewData["Title"] = "Manage - " + Model.DisplayName;
}

<div class="max-w-4xl mx-auto py-10 px-4">
    
    <div class="mb-6">
        <a asp-action="Index" class="text-sm font-bold text-[#008080] hover:text-[#006666] flex items-center no-underline">
            <i class="ri-arrow-left-line mr-1"></i> Back to Staff List
        </a>
    </div>

    <div class="bg-white shadow-2xl rounded-2xl overflow-hidden border border-gray-100">
        
        <div class="bg-gray-50 p-8 border-b border-gray-200">
            <div class="flex items-center">
                <div class="h-20 w-20 bg-[#008080] rounded-full flex items-center justify-center text-white text-3xl font-bold">
                    @Model.FirstName.Substring(0, 1)
                </div>
                <div class="ml-6">
                    <h2 class="text-2xl font-bold text-gray-900">@Model.DisplayName</h2>
                    <p class="text-gray-500">@Model.Email</p>
                    <div class="mt-2">
                        <span class="px-3 py-1 text-xs font-bold rounded-full border @Model.StatusClasses">
                            @Model.StatusLabel
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="p-8 grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-4">
                <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest">Database Record</h3>
                
                <div class="grid grid-cols-2 gap-4">
                    <div class="bg-gray-50 p-3 rounded-lg">
                        <label class="text-[10px] text-gray-500 uppercase font-bold">First Name</label>
                        <p class="font-bold text-gray-800">@Model.FirstName</p>
                    </div>
                    <div class="bg-gray-50 p-3 rounded-lg">
                        <label class="text-[10px] text-gray-500 uppercase font-bold">Surname</label>
                        <p class="font-bold text-gray-800">@Model.Surname</p>
                    </div>
                </div>
                
                <div class="bg-gray-50 p-4 rounded-xl">
                    <label class="text-[10px] text-gray-500 uppercase font-bold">Access Level (Role)</label>
                    <p class="font-bold text-gray-800">@Model.Role</p>
                </div>
            </div>

            <div class="space-y-4">
                <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest">Control Panel</h3>
                
                <button type="button" 
                        onclick="if(confirm('Toggle user access status?')) { document.getElementById('toggleForm').submit(); }"
                        class="w-full flex items-center justify-between p-4 rounded-xl border-2 transition @(Model.IsActive ? "border-red-100 text-red-600 hover:bg-red-50" : "border-green-100 text-green-600 hover:bg-green-50")">
                    <span class="font-bold">@(Model.IsActive ? "Suspend Access" : "Restore Access")</span>
                    <i class="ri-shut-down-line text-2xl"></i>
                </button>

                <button type="button" 
                        onclick="if(confirm('Reset password to JADirect@2026?')) { document.getElementById('resetForm').submit(); }"
                        class="w-full flex items-center justify-between p-4 rounded-xl border-2 border-slate-100 text-slate-600 hover:bg-slate-50 transition">
                    <span class="font-bold">Reset Password</span>
                    <i class="ri-key-2-line text-2xl"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<form id="toggleForm" asp-action="ToggleStatus" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.UserId" />
</form>

<form id="resetForm" asp-action="ResetPassword" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.UserId" />
</form>