@{
    ViewData["Title"] = "Manager Dashboard";
}

<div class="container mt-4">
    <div class="alert alert-info shadow-sm" style="border-radius: 15px;">
        <h2 class="fw-bold"><i class="bi bi-speedometer2"></i> Manager Dashboard</h2>
        <p>Welcome, <strong>@User.Identity.Name</strong>. You are logged in as a Manager.</p>
        <hr>
        <p class="mb-0">The fleet oversight modules will be implemented in the next phase.</p>
    </div>

    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3 mb-3" style="border-radius: 15px; background-color: #f8f9fa;">
                <h5>Total Vehicles</h5>
                <h2 class="text-teal fw-bold">--</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3 mb-3" style="border-radius: 15px; background-color: #f8f9fa;">
                <h5>Active Inspections</h5>
                <h2 class="text-warning fw-bold">--</h2>
            </div>
        </div>
    </div>
</div>