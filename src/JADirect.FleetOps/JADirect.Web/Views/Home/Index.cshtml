@model JADirect.Domain.Models.VehicleStatusViewModel

@{
    ViewData["Title"] = "Home - Driver Panel";
    
    // Mapeamento de cores CSS baseado no StatusColor do novo ViewModel
    string borderClass = Model.StatusColor == "Green" ? "border-success" : 
                        Model.StatusColor == "Yellow" ? "border-warning" : "border-danger";
    
    string textClass = Model.StatusColor == "Green" ? "text-success" : 
                      Model.StatusColor == "Yellow" ? "text-warning" : "text-danger";

    // Lógica inversa: Se NÃO é permitido o Daily Log, a ação de Walkaround é requerida/crítica
    bool isActionRequired = !Model.IsDailyLogAllowed;
}

<style>
    .home-card {
        border-radius: 20px;
        border-width: 3px;
    }
    .btn-fat-finger {
        min-height: 70px; 
        font-size: 1.2rem;
        font-weight: bold;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 15px;
        margin-bottom: 15px;
    }
    .status-icon {
        font-size: 3rem;
    }
</style>

<div class="container mt-4">
    <div class="card shadow-sm mb-4 home-card @borderClass">
        <div class="card-body text-center p-4">
            <h5 class="text-muted text-uppercase mb-1">Operating Vehicle</h5>
            <h1 class="display-4 fw-bold mb-3">@ViewBag.RegistrationNo</h1>
            
            <div class="d-flex justify-content-center align-items-center">
                <i class="bi bi-shield-check status-icon @textClass"></i>
                <div class="ms-3 text-start">
                    <h4 class="mb-0 @textClass">@Model.StatusColor Status</h4>
                    <p class="mb-0 text-secondary">@Model.StatusMessage</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            
            @* Se o acesso ao Daily Log está bloqueado, destacamos o botão de Walkaround em Vermelho *@
            <a asp-controller="Walkaround" asp-action="Create" 
               class="btn @(isActionRequired ? "btn-danger" : "btn-outline-secondary") btn-fat-finger w-100 shadow-sm">
                <i class="bi bi-clipboard-check-fill me-2 fs-3"></i> 
                @(isActionRequired ? "START REQUIRED WALKAROUND" : "Retake Safety Check")
            </a>

            @if (isActionRequired)
            {
                <button class="btn btn-secondary btn-fat-finger w-100 opacity-50 shadow-sm" disabled>
                    <i class="bi bi-lock-fill me-2 fs-3"></i> Daily Log (Walkaround Required)
                </button>
                <div class="alert alert-danger text-center mt-2 border-0">
                    <small><i class="bi bi-exclamation-triangle"></i> Complete the safety check to unlock daily logs.</small>
                </div>
            }
            else
            {
                <a asp-controller="DailyLog" asp-action="Create" 
                   class="btn btn-success btn-fat-finger w-100 shadow-sm" 
                   style="background-color: #008080; border: none;">
                    <i class="bi bi-truck me-2 fs-3"></i> START DAILY LOG
                </a>
            }
            
            <div class="mt-4 text-center">
                <a asp-controller="Driver" asp-action="SelectVehicle" class="text-decoration-none text-muted">
                    <i class="bi bi-arrow-left-right"></i> Change Vehicle
                </a>
            </div>
        </div>
    </div>
</div>