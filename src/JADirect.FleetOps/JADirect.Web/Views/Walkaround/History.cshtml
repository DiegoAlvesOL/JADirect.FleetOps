@model IEnumerable<JADirect.Domain.Models.WalkaroundHistoryViewModel>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2>Audit History</h2>
        <span class="badge bg-secondary fs-5">@ViewBag.RegistrationNo</span>
    </div>
    <hr />

    <div class="table-responsive">
        <table class="table table-hover shadow-sm align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Date</th>
                    <th>Vehicle</th> @* Nova coluna adicionada *@
                    <th>Driver</th>
                    <th>Odometer</th>
                    <th>Status</th>
                    <th>Location</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    @* Nota: Usei item.hasDefect conforme definido no seu ViewModel *@
                    <tr class="@(item.hasDefect ? "table-danger" : "")">
                        <td>@item.CheckDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td><strong>@item.RegistrationNo</strong></td>
                        <td>@item.DriverName</td>
                        <td>@item.Odometer KM</td>
                        <td>
                            @if (item.hasDefect)
                            {
                                <span class="badge bg-danger">
                                    <i class="bi bi-exclamation-octagon"></i> DEFECT: @item.DefectNotes
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success">
                                    <i class="bi bi-check-circle"></i> PASS
                                </span>
                            }
                        </td>
                        <td>
                            @if (item.Latitude.HasValue && item.Longitude.HasValue)
                            {
                                @* Link dinâmico usando as coordenadas reais do banco *@
                                <a href="https://www.google.com/maps/search/?api=1&query=@item.Latitude,@item.Longitude" 
                                   target="_blank" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-geo-alt"></i> View on Map
                                </a>
                            }
                            else
                            {
                                <span class="text-muted small">No GPS Data</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <div class="mt-4 mb-5">
        <a asp-action="Index" asp-controller="Home" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
    </div>
</div>